# GrantAI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Backend (Spring Boot) ──────────────────────────────────────────
JWT_SECRET=change_me_to_a_32_char_random_secret
JWT_COOKIE_DOMAIN=grantai-demo.vercel.app
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/grantai
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=grantai_dev_ai_key
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── AI Engine (FastAPI) ────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash
DATABASE_URL=sqlite:///./data/grants.db
# AI_ENGINE_API_KEY and CORS_ALLOWED_ORIGINS are shared with the backend section above;
# set the following overrides in the AI engine's own .env if values differ:
# AI_ENGINE_API_KEY=grantai_dev_ai_key
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Frontend (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_AI_ENGINE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
